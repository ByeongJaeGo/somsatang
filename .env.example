# Vercel 프로젝트 Environment Variables에 아래 값을 넣으세요.
# (Settings → Environment Variables)

# Resend API 키 (https://resend.com 가입 후 API Keys에서 발급)
RESEND_API_KEY=re_xxxxxxxx

# 사전 등록 알림을 받을 본인 이메일
NOTIFY_EMAIL=you@example.com

# (선택) 발신 주소. 도메인 인증 전에는 Resend 기본값 사용
# NOTIFY_FROM=somsatang <onboarding@resend.dev>
